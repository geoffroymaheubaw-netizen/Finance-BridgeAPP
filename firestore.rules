rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for UserProfile to prevent "Update-Gaps" and Shadow Fields
    function isValidUserProfile(data) {
      return data.keys().hasAll(['username', 'xp', 'level', 'streak', 'cash', 'completedLessons', 'portfolio', 'transactions', 'portfolioHistory'])
        && data.keys().size() <= 13
        && data.username is string && data.username.size() > 0 && data.username.size() <= 100
        && data.xp is int && data.xp >= 0
        && data.level is int && data.level >= 1
        && data.streak is int && data.streak >= 0
        && data.cash is number
        && data.completedLessons is list && data.completedLessons.size() <= 1000
        && data.portfolio is list && data.portfolio.size() <= 1000
        && data.transactions is list && data.transactions.size() <= 5000
        && data.portfolioHistory is list && data.portfolioHistory.size() <= 10000
        && (!data.keys().hasAny(['marketMode']) || data.marketMode is string)
        && (!data.keys().hasAny(['learningHearts']) || data.learningHearts is int)
        && (!data.keys().hasAny(['lastHeartsResetDate']) || data.lastHeartsResetDate is string)
        && (!data.keys().hasAny(['lastActive']) || data.lastActive is string || data.lastActive == null);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(userId) 
        && isValidUserProfile(request.resource.data);

      allow update: if isOwner(userId) 
        && isValidId(userId) 
        && isValidUserProfile(request.resource.data)
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'username', 'xp', 'level', 'streak', 'lastActive', 'cash', 
            'completedLessons', 'portfolio', 'transactions', 'portfolioHistory', 
            'marketMode', 'learningHearts', 'lastHeartsResetDate'
          ])
        );

      allow delete: if false;
    }
  }
}
